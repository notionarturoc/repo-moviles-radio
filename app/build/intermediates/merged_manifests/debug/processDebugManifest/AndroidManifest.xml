<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================================
    Tomorrowland Audio Player - AndroidManifest.xml
    Archivo de configuración principal de la aplicación
    ============================================================================
    
    Este archivo define:
    - Permisos requeridos por la aplicación
    - Componentes de la aplicación (Activities, Services, etc.)
    - Configuración del tema y nombre de la app
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.tomorrowland.audioplayer"
    android:versionCode="1"
    android:versionName="1.0.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <!--
         ====================================================================
         PERMISOS DE LA APLICACIÓN
         ====================================================================
    -->


    <!-- Permiso de Internet: Necesario para cargar imágenes y streaming de audio -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Permiso de estado de red: Para verificar conectividad -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Permiso de Foreground Service: Para mantener la reproducción en segundo plano -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <permission
        android:name="com.tomorrowland.audioplayer.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.tomorrowland.audioplayer.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />
    <!--
 ====================================================================
         CONFIGURACIÓN DE LA APLICACIÓN
         ====================================================================
    -->
    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.TomorrowlandAudioPlayer"
        android:usesCleartextTraffic="true" >

        <!--
             =================================================================
             MainActivity: Actividad principal de la aplicación
             Es el punto de entrada y contiene el NavHostFragment
             =================================================================
        -->
        <activity
            android:name="com.tomorrowland.audioplayer.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize" >

            <!-- Intent Filter: Define esta actividad como el launcher de la app -->
            <intent-filter>

                <!-- Acción MAIN: Esta es la actividad principal -->
                <action android:name="android.intent.action.MAIN" />

                <!-- Categoría LAUNCHER: Aparece en el launcher del dispositivo -->
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.tomorrowland.audioplayer.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>