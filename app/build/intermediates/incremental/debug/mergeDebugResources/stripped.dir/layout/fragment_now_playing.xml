<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================================
    Tomorrowland Audio Player - Now Playing Fragment (Reproductor Completo)
    ============================================================================
    
    🎧 PANTALLA NOW PLAYING:
    
    Esta es la pantalla de reproducción completa. Contiene:
    1. Header con botón de volver y título
    2. Album Art grande con efecto glow
    3. Información del track (título, artista, favorito)
    4. Barra de progreso con tiempos
    5. Controles de reproducción completos
    6. Información de streaming
    
    🎨 EFECTO GLOW:
    Se logra colocando una imagen blur detrás del album art principal.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="@dimen/padding_standard"
    tools:context=".ui.nowplaying.NowPlayingFragment">

    <!-- ====================================================================
         HEADER
         ==================================================================== -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_lg">

        <!-- Botón Volver (expand_more = minimizar) -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_expand_more"
            app:tint="@color/text_primary"
            android:contentDescription="@string/cd_back_button" />

        <!-- Centro: NOW PLAYING + Tomorrowland Radio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/label_now_playing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/now_playing"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_overline"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/label_radio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tomorrowland_radio"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Botón Más opciones -->
        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            app:tint="@color/text_primary"
            android:contentDescription="@string/cd_menu_button" />
    </LinearLayout>

    <!-- ====================================================================
         ALBUM ART CON EFECTO GLOW
         ==================================================================== -->
    
    <!-- Efecto Glow (imagen blur detrás) -->
    <ImageView
        android:id="@+id/album_art_glow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:alpha="0.5"
        android:src="@drawable/bg_gradient_tomorrowland"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_xl" />

    <!-- Album Art Principal -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/album_art"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_gradient_tomorrowland"
        app:shapeAppearanceOverlay="@style/RoundedImageView"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.75"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_xxl"
        android:elevation="@dimen/elevation_high"
        android:contentDescription="@string/cd_album_art" />

    <!-- ====================================================================
         INFORMACIÓN DEL TRACK
         ==================================================================== -->
    <LinearLayout
        android:id="@+id/track_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/album_art"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_xl">

        <!-- Título y Artista -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Título del Track -->
            <TextView
                android:id="@+id/track_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_headline"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Live at Tomorrowland 2024" />

            <!-- Artista -->
            <TextView
                android:id="@+id/track_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_subtitle"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="@dimen/margin_xs"
                tools:text="Dimitri Vegas &amp; Like Mike" />
        </LinearLayout>

        <!-- Botón Favorito -->
        <ImageButton
            android:id="@+id/btn_favorite"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_favorite_border"
            app:tint="@color/text_primary"
            android:contentDescription="@string/cd_favorite_button" />
    </LinearLayout>

    <!-- ====================================================================
         BARRA DE PROGRESO
         ==================================================================== -->
    <SeekBar
        android:id="@+id/progress_seekbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="40"
        android:progressTint="@color/primary"
        android:thumbTint="@color/primary"
        android:progressBackgroundTint="@color/progress_track"
        app:layout_constraintTop_toBottomOf="@id/track_info"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_lg"
        android:contentDescription="@string/cd_progress_bar" />

    <!-- Tiempos -->
    <TextView
        android:id="@+id/current_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_caption"
        app:layout_constraintTop_toBottomOf="@id/progress_seekbar"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="1:42" />

    <TextView
        android:id="@+id/total_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_caption"
        app:layout_constraintTop_toBottomOf="@id/progress_seekbar"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="4:15" />

    <!-- ====================================================================
         CONTROLES DE REPRODUCCIÓN
         ==================================================================== -->
    <LinearLayout
        android:id="@+id/playback_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/current_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_lg">

        <!-- Botón Shuffle -->
        <ImageButton
            android:id="@+id/btn_shuffle"
            android:layout_width="@dimen/control_button_size"
            android:layout_height="@dimen/control_button_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_shuffle"
            app:tint="@color/text_secondary"
            android:contentDescription="@string/cd_shuffle_button" />

        <!-- Botón Previous -->
        <ImageButton
            android:id="@+id/btn_previous"
            android:layout_width="@dimen/control_button_size"
            android:layout_height="@dimen/control_button_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_previous"
            app:tint="@color/text_primary"
            android:layout_marginStart="@dimen/margin_lg"
            android:contentDescription="@string/cd_previous_button" />

        <!-- Botón Play/Pause (Grande) -->
        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="@dimen/play_button_size"
            android:layout_height="@dimen/play_button_size"
            android:background="@drawable/bg_circle_primary"
            android:src="@drawable/ic_pause"
            android:padding="18dp"
            app:tint="@color/on_primary"
            android:layout_marginHorizontal="@dimen/margin_lg"
            android:elevation="@dimen/elevation_medium"
            android:contentDescription="@string/cd_play_button" />

        <!-- Botón Next -->
        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="@dimen/control_button_size"
            android:layout_height="@dimen/control_button_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_next"
            app:tint="@color/text_primary"
            android:layout_marginEnd="@dimen/margin_lg"
            android:contentDescription="@string/cd_next_button" />

        <!-- Botón Repeat -->
        <ImageButton
            android:id="@+id/btn_repeat"
            android:layout_width="@dimen/control_button_size"
            android:layout_height="@dimen/control_button_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_repeat"
            app:tint="@color/text_secondary"
            android:contentDescription="@string/cd_repeat_button" />
    </LinearLayout>

    <!-- ====================================================================
         BADGE DE STREAMING
         ==================================================================== -->
    <LinearLayout
        android:id="@+id/streaming_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_glass"
        android:padding="@dimen/padding_md"
        app:layout_constraintTop_toBottomOf="@id/playback_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_xl">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_graphic_eq" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/streaming_from_youtube"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_overline"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/margin_sm" />
    </LinearLayout>

    <!-- ====================================================================
         BARRA INFERIOR (AirPlay + Queue)
         ==================================================================== -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingBottom="@dimen/padding_lg">

        <!-- Botón AirPlay/Devices -->
        <ImageButton
            android:id="@+id/btn_devices"
            android:layout_width="@dimen/control_button_size"
            android:layout_height="@dimen/control_button_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_devices"
            app:tint="@color/text_secondary"
            android:contentDescription="@string/airplay" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Botón Queue/Up Next -->
        <ImageButton
            android:id="@+id/btn_queue"
            android:layout_width="@dimen/control_button_size"
            android:layout_height="@dimen/control_button_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_queue_music"
            app:tint="@color/text_secondary"
            android:contentDescription="@string/queue" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
