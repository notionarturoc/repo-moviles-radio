<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================================
    Tomorrowland Audio Player - Item Track (Elemento de Lista)
    ============================================================================
    
    🎵 TRACK ITEM:
    
    Este layout define cómo se ve cada track en la lista.
    Componentes:
    - Thumbnail circular de la canción
    - Título y artista
    - Badge opcional (JSON_SRC, YT_DATA_V3, etc.)
    - Botón de reproducir
    
    📝 PATRÓN VIEWHOLDER:
    Este layout se usa con el RecyclerView Adapter.
    Cada instancia se "recicla" cuando sale de la pantalla.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_track_item"
    android:padding="@dimen/padding_md"
    android:clickable="true"
    android:focusable="true">

    <!-- Número de track -->
    <TextView
        android:id="@+id/track_number"
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_tertiary"
        android:textSize="@dimen/text_body"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/track_thumbnail"
        app:layout_constraintBottom_toBottomOf="@id/track_thumbnail"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="1" />

    <!-- Thumbnail circular del track -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/track_thumbnail"
        android:layout_width="@dimen/track_thumbnail_size"
        android:layout_height="@dimen/track_thumbnail_size"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_placeholder_album"
        android:background="@color/surface_variant"
        app:shapeAppearanceOverlay="@style/CircleImageView"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/track_number"
        android:layout_marginStart="@dimen/margin_sm"
        android:contentDescription="@string/cd_track_thumbnail" />

    <!-- Contenedor de información del track -->
    <LinearLayout
        android:id="@+id/track_info_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/margin_md"
        android:layout_marginEnd="@dimen/margin_md"
        app:layout_constraintTop_toTopOf="@id/track_thumbnail"
        app:layout_constraintBottom_toBottomOf="@id/track_thumbnail"
        app:layout_constraintStart_toEndOf="@id/track_thumbnail"
        app:layout_constraintEnd_toStartOf="@id/btn_play">

        <!-- Título del track -->
        <TextView
            android:id="@+id/track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Pura Vida" />

        <!-- Artista -->
        <TextView
            android:id="@+id/track_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            tools:text="Armin van Buuren" />

        <!-- Badge contenedor -->
        <LinearLayout
            android:id="@+id/badge_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_xs"
            android:visibility="visible">

            <!-- Badge (JSON_SRC, YT_DATA_V3, etc.) -->
            <TextView
                android:id="@+id/track_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_overline"
                android:textStyle="bold"
                android:background="@drawable/bg_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:visibility="gone"
                tools:text="JSON_SRC"
                tools:visibility="visible" />

            <!-- Duración -->
            <TextView
                android:id="@+id/track_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_caption"
                android:layout_marginStart="@dimen/margin_sm"
                tools:text="3:45" />
        </LinearLayout>
    </LinearLayout>

    <!-- Botón de reproducir -->
    <ImageButton
        android:id="@+id/btn_play"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_circle_surface"
        android:src="@drawable/ic_play"
        android:padding="10dp"
        app:tint="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/cd_play_button" />

</androidx.constraintlayout.widget.ConstraintLayout>
